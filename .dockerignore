# 1. 一旦すべてを無視
*

# 2. サブモジュールと Git 情報を「深く」許可
!/.git/
!/.git/**
!/.gitmodules

# 3. 各ディレクトリの中身を再帰的に許可 (/** をつけるのがコツ)
!/zsh/
!/zsh/**
!/configs/
!/configs/**
!/oh-my-zsh/
!/oh-my-zsh/**
!/bin/
!/bin/**
!/scripts/
!/scripts/**
!/common/
!/common/**
!/bash/
!/bash/**

# 4. ルートにある必須ファイルを許可
!/install.sh
!/Dockerfile
!/README.md
!/.mailmap

# 5. 最後に、機密情報や不要な重いデータだけをピンポイントで除外
.env
*.key
*.local
node_modules/
dist/
