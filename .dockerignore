# 1. デフォルトですべてを無視（ホワイトリスト方式）
*

# 2. 必要なディレクトリを「フォルダごと」許可
!/scripts/
!/common/
!/bin/
!/zsh/         # ← これ重要！ .zshrc の本体がここにあるなら必須
!/oh-my-zsh/   # ← サブモジュールとして管理してるなら必須

# 3. 必要なルートファイルを許可
!/install.sh
!/Dockerfile
!/.git/
# 4. 秘密情報や不要な重いデータは「絶対に」除外 (上書き)
.env
*.key
*.local
assets/
README.md
LICENSE
