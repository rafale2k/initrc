#!/bin/bash

# 1. バージョン情報の取得と更新
CURRENT_VERSION=$(cat VERSION)
echo "Current version: $CURRENT_VERSION"
read -p "Enter new version (Press Enter to auto-bump): " NEW_VERSION

# 自動インクリメント
if [ -z "$NEW_VERSION" ]; then
    NEW_VERSION=$(echo $CURRENT_VERSION | awk -F. '{$NF = $NF + 1;} 1' OFS=.)
fi

# 以降で使用する変数を統一
VERSION="v$NEW_VERSION"      # タグ用 (v1.33.2)
DOCK_VER="$NEW_VERSION"      # Docker/ファイル書き込み用 (1.33.2)
DOCKER_REPO="rafale2k/initrc"

echo "🚀 Preparing Release $VERSION..."

# 2. ファイルの更新
echo "$DOCK_VER" > VERSION
# READMEのバッジを更新（正規表現をルーズにして確実に置換）
sed -i "s/version-.*-blue/version-v${DOCK_VER}-blue/g" README.md

# 3. 前回のタグからの差分を最新10件に絞って取得
PREV_TAG=$(git describe --tags --abbrev=0 2>/dev/null)

if [ -z "$PREV_TAG" ]; then
    CHANGELOG=$(git log --oneline -n 10)
    DIFF_DATA=$(git log --oneline --stat -n 10)
else
    CHANGELOG=$(git log ${PREV_TAG}..HEAD --oneline -n 10)
    DIFF_DATA=$(git log ${PREV_TAG}..HEAD --oneline --stat -n 10)
fi

# Gemini用の作業ファイル作成
echo "Current Changes:" > Update.md
echo "$CHANGELOG" >> Update.md

# 4. Lint Check
echo "🔍 Running lint..."
find . -type f \( -name "*.sh" -o -name "*.zsh" \) \
    -not -path "*/.git/*" \
    -not -path "*/oh-my-zsh/*" \
    -not -path "*/plugins/*" \
    -not -path "*/themes/*" \
    -not -path "*/templates/*" \
    | xargs shellcheck

# 5. AI Summary
echo "🤖 Generating AI summary..."
AI_SUMMARY=$(echo "$DIFF_DATA" | llm -s "SREとして、今回の変更を3行で情熱的に日本語で要約して。各行に絵文字を付けて。")

# 6. CHANGELOG.md 更新
~/dotfiles/bin/gen-changelog "$VERSION"

if [ -n "$AI_SUMMARY" ]; then
    TEMP_FILE=$(mktemp)
    # 修正ポイント：awk内の改行とクォートを安全な形式に変更
    awk -v summary="> ### 🤖 AI Release Summary\n> $AI_SUMMARY\n\n---" '
    BEGIN { done = 0 }
    /## \[/ && done == 0 { print; print "\n" summary; done = 1; next }
    { print }' CHANGELOG.md > "$TEMP_FILE" && mv "$TEMP_FILE" CHANGELOG.md
fi

# 7. README.md への最新ノート同期
echo "🐳 Syncing to README.md..."
LATEST_NOTES=$(awk '/^## \[/ { count++; if (count > 1) exit; } { if (count == 1) print }' CHANGELOG.md)

# マーカーの定義（一文字ずつ打ち込んだ通り）
START_MARKER="<!-- RELEASE_NOTES_START -->"
END_MARKER="<!-- RELEASE_NOTES_END -->"

# LATEST_NOTES が空（バージョン行以外に中身がない）場合はスキップ
if [ -z "$(echo "$LATEST_NOTES" | grep -v '^## \[')" ]; then
    echo "⚠️  Skip: No new release notes found. Keeping current README."
else
    # 画像パスを GitHub の絶対 URL に置換
    LATEST_NOTES=$(echo "$LATEST_NOTES" | sed "s|\./assets/|https://raw.githubusercontent.com/rafale2k/initrc/main/assets/|g")

    if [ -f README.md ] && grep -q "$START_MARKER" README.md; then
        TMP_README=$(mktemp)
        sed -n "1,/$START_MARKER/p" README.md > "$TMP_README"
        echo -e "\n$LATEST_NOTES\n" >> "$TMP_README"
        sed -n "/$END_MARKER/,\$p" README.md >> "$TMP_README"
        mv "$TMP_README" README.md
        echo "✅ README.md updated."
    else
        echo "⚠️  Skip: README.md marker not found."
    fi
fi

# 8. Git Commit & Tag
git add CHANGELOG.md README.md VERSION
if ! git diff --staged --quiet; then
    git commit -m "chore: release $VERSION"
fi
git tag -af "$VERSION" -m "Release $VERSION"

# 9. Docker Build & Push
echo "🐳 Building Docker image..."
DOCKER_BUILDKIT=1 docker build -t "$DOCKER_REPO:$DOCK_VER" .
docker tag "$DOCKER_REPO:$DOCK_VER" "$DOCKER_REPO:latest"
docker push "$DOCKER_REPO:$DOCK_VER"
docker push "$DOCKER_REPO:latest"

# 10. Final Push（強制プッシュで Actions との歴史のズレを解消）
git push origin main --force --tags

# 11. 掃除
rm -f Update.md

echo "✨ Successfully released $VERSION!"
