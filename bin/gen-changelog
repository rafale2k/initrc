#!/bin/bash
# bin/gen-changelog: ログ件数制限 & v-prefix 完全対応版

# 1. バージョン名の整形
INPUT_VERSION=${1:-$(git describe --tags --match "v*" --abbrev=0 2>/dev/null)}
[[ $INPUT_VERSION != v* ]] && VERSION="v$INPUT_VERSION" || VERSION="$INPUT_VERSION"

DATE=$(date +%Y-%m-%d)
OUTPUT="CHANGELOG.md"

# 2. 比較対象となる「一つ前のタグ」を探す
PREV_TAG=$(git describe --tags --match "v*" --abbrev=0 "${VERSION}^" 2>/dev/null || echo "")

echo "📖 Generating changelog: $PREV_TAG -> $VERSION"

{
    echo "## [$VERSION] - $DATE"
    if [ -n "$PREV_TAG" ]; then
        # ★ 修正ポイント：最新の5件だけに絞る
        git log "${PREV_TAG}..HEAD" --pretty=format:"- %s (%h)" --no-merges -n 5
        
        # 5件以上ある場合は「...and more」を表示
        TOTAL_CHANGES=$(git rev-list --count "${PREV_TAG}..HEAD")
        if [ "$TOTAL_CHANGES" -gt 5 ]; then
            echo -e "\n- ... and $((TOTAL_CHANGES - 5)) more changes."
        fi
    else
        # 初回リリース用（ここも5件に制限）
        git log --pretty=format:"- %s (%h)" --no-merges -n 5
    fi
    echo -e "\n"
} > "NEW_RELEASE.md"

# 3. CHANGELOG.md の先頭に挿入する
if [ -f "$OUTPUT" ]; then
    cat NEW_RELEASE.md "$OUTPUT" > TEMP_LOG.md && mv TEMP_LOG.md "$OUTPUT"
else
    mv NEW_RELEASE.md "$OUTPUT"
fi

rm -f NEW_RELEASE.md
echo "✅ $OUTPUT updated with $VERSION content."
